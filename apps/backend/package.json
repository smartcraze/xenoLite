{
  "name": "backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run build && bun run dist/index.js",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/db": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.69",
    "@faker-js/faker": "^10.4.0",
    "@types/morgan": "^1.9.10",
    "ai": "^6.0.199",
    "bullmq": "^5.78.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "zod": "^4.4.3"
  }
}
